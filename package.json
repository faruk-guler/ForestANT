  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently \"cd backend-go && go run main.go\" \"npm run dev --prefix frontend\"",
    "build": "npm run build:ui",
    "build:ui": "npm run build --prefix frontend",
    "serve": "cd backend-go && go run main.go",
    "full-clean": "powershell -Command \"Remove-Item -Recurse -Force node_modules, frontend/node_modules, frontend/dist -ErrorAction SilentlyContinue; Get-ChildItem -Path backend-go -Filter *.db* | Remove-Item -Force; Get-ChildItem -Path backend-go -Filter *.exe | Remove-Item -Force\""
  },
