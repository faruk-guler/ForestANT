# ─────────────────────────────────────────────────────────────
#  ForestANT v3.0 — Environment Configuration
#  Dosya konumu: /opt/forestant/.env
#  Düzenledikten sonra: sudo systemctl restart forestant
# ─────────────────────────────────────────────────────────────

# ── Sunucu ────────────────────────────────────────────────────
# Dinlenecek port (80 için setcap gerekir, 8080 için gerekmez)
PORT=80

# ── Tarama Ayarları ───────────────────────────────────────────
# Otomatik tarama aralığı (saat cinsinden)
# Özel değer: 5 → 5 DAKİKA (test modu)
# Örnek: 6, 12, 24, 48
SCAN_INTERVAL=24

# ── Bildirim Eşiği ────────────────────────────────────────────
# Kaç gün kala uyarı gönderilsin
NOTIFICATION_THRESHOLD=30

# ─────────────────────────────────────────────────────────────
#  BİLDİRİM KANALLARI
#  (Kullanmayacaklarınızı boş bırakın)
# ─────────────────────────────────────────────────────────────

# ── Generic Webhook ───────────────────────────────────────────
# Her türlü webhook URL'si (Discord formatı ile uyumlu)
WEBHOOK_URL=

# ── Telegram ──────────────────────────────────────────────────
# Bot token: BotFather'dan alınır
# Chat ID: @userinfobot ile öğrenilir
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord ───────────────────────────────────────────────────
# Discord > Kanal Ayarları > Entegrasyonlar > Webhook
DISCORD_WEBHOOK_URL=

# ── Slack ─────────────────────────────────────────────────────
# Slack > Apps > Incoming Webhooks
SLACK_WEBHOOK_URL=

# ── SMTP E-Posta ──────────────────────────────────────────────
# Gmail için: smtp.gmail.com:587 (App Password kullanın)
# Outlook için: smtp.office365.com:587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# ─────────────────────────────────────────────────────────────
#  ACME / Let's Encrypt
# ─────────────────────────────────────────────────────────────
# Sertifika üretimi için e-posta adresi
ACME_EMAIL=admin@example.com

# Staging: test için (gerçek sertifika üretmez, rate limit yok)
# Production: gerçek sertifika üretir
# ACME_MODE=staging   (varsayılan)
# ACME_MODE=production
ACME_MODE=staging
